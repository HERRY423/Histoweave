// HistoWeave Nextflow configuration.

manifest {
    name            = 'histoweave-spatial/histoweave'
    description     = 'Reproducible spatial transcriptomics pipeline.'
    nextflowVersion = '>=23.10.0'
    version         = '0.0.1'
}

// Config selectors are evaluated before main.nf, so declare values referenced below here too.
params.r_image = 'ghcr.io/histoweave-spatial/histoweave-r:0.0.1'

docker {
    enabled = false
    // The project image exposes a CLI entrypoint; Nextflow must launch its task shell directly.
    runOptions = '--entrypoint ""'
}
singularity {
    enabled = false
    autoMounts = true
}

process {
    executor       = 'local'
    time           = '1h'
    memory         = '4 GB'
    cpus           = 2
    errorStrategy  = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
    maxRetries     = 2
    maxErrors      = -1
}

process {
    withLabel: 'low_mem' {
        memory = '2 GB'
        cpus   = 1
        time   = '30m'
    }
    withLabel: 'domain_detection' {
        memory = { 8.GB * task.attempt }
        cpus   = { 4 * task.attempt }
        time   = '4h'
    }
    withLabel: 'deconvolution' {
        memory = { 16.GB * task.attempt }
        cpus   = { 8 * task.attempt }
        time   = '8h'
    }
    withLabel: 'r_method' {
        container = { params.r_image }
    }
}

profiles {
    standard {
        process.executor   = 'local'
        docker.enabled     = false
        singularity.enabled = false
    }
    local {
        process.executor   = 'local'
        docker.enabled     = false
        singularity.enabled = false
    }
    // Composable with local/docker/singularity: `-profile local,test` is the CI smoke run.
    test {
        params.demo        = true
        params.n_domains   = 3
        params.steps       = 'qc,normalize,domain_detection,report'
        process.cpus       = 1
        process.memory     = '2 GB'
        process.time       = '30m'
    }
    docker {
        process.executor   = 'local'
        docker.enabled     = true
        singularity.enabled = false
    }
    singularity {
        process.executor   = 'local'
        docker.enabled     = false
        singularity.enabled = true
    }
    slurm {
        process.executor   = 'slurm'
        docker.enabled     = false
        singularity.enabled = true
    }
    kubernetes {
        process.executor   = 'k8s'
        docker.enabled     = false
        singularity.enabled = false
    }
    aws {
        process.executor  = 'awsbatch'
        process.queue     = 'histoweave-queue'
    }
    conda {
        docker.enabled = false
        process.conda  = 'histoweave-env'
    }
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_trace.tsv"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,attempt,submit,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}
