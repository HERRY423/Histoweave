<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>HistoWeave report · {{ assay }}</title>
<style>
  :root { color-scheme: light dark; }
  body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
         max-width: 1200px; margin: 2rem auto; padding: 0 1.25rem; line-height: 1.5;
         color: #1a1a2e; background: #fff; }
  @media (prefers-color-scheme: dark) {
    body { color: #e6e6f0; background: #14141b; }
    .card { background: #1e1e28 !important; border-color: #2c2c3a !important; }
    th { background: #232330 !important; }
    code { background: #232330 !important; }
    .vitessce-container { border-color: #2c2c3a !important; }
  }
  header { border-bottom: 3px solid #4C78A8; padding-bottom: .75rem; margin-bottom: 1.5rem; }
  h1 { margin: 0; font-size: 1.6rem; }
  .sub { color: #7a7a8c; font-size: .9rem; }
  h2 { font-size: 1.15rem; margin-top: 2rem; border-left: 4px solid #4C78A8;
       padding-left: .6rem; }
  .grid { display: flex; flex-wrap: wrap; gap: 1rem; }
  .card { flex: 1 1 150px; background: #f7f8fa; border: 1px solid #e3e6ea;
          border-radius: 10px; padding: .9rem 1rem; }
  .card .k { font-size: 1.5rem; font-weight: 700; }
  .card .l { font-size: .78rem; color: #7a7a8c; text-transform: uppercase;
             letter-spacing: .04em; }
  .plots { display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-start; }
  table { border-collapse: collapse; width: 100%; font-size: .88rem; margin-top: .5rem; }
  th, td { text-align: left; padding: .45rem .6rem; border-bottom: 1px solid #e3e6ea; }
  th { background: #f2f4f7; font-weight: 600; }
  code { background: #f2f4f7; padding: .1rem .35rem; border-radius: 4px; font-size: .85em; }
  .overflow { overflow-x: auto; }
  footer { margin-top: 3rem; font-size: .8rem; color: #9a9aa8;
           border-top: 1px solid #e3e6ea; padding-top: 1rem; }

  /* Vitessce container */
  .vitessce-container { border: 2px solid #e3e6ea; border-radius: 10px;
                        min-height: 520px; margin: 1rem 0; overflow: hidden; }
  .vitessce-error { padding: 2rem; color: #E45756; text-align: center;
                    font-style: italic; }
  .vitessce-loading { padding: 2rem; text-align: center; color: #7a7a8c;
                      font-style: italic; }
</style>
</head>
<body>
<header>
  <h1>HistoWeave Analysis Report</h1>
  <div class="sub">assay: <b>{{ assay }}</b> · generated {{ generated }} ·
    histoweave v{{ histoweave_version }}</div>
</header>

<h2>Overview</h2>
<div class="grid">
  <div class="card"><div class="k">{{ n_obs }}</div><div class="l">Observations</div></div>
  <div class="card"><div class="k">{{ n_vars }}</div><div class="l">Genes</div></div>
  <div class="card"><div class="k">{{ n_domains }}</div><div class="l">Domains found</div></div>
  {% if qc %}
  <div class="card"><div class="k">{{ qc.n_removed }}</div><div class="l">Cells removed (QC)</div></div>
  {% endif %}
</div>

{% if qc %}
<h2>Quality control</h2>
<div class="grid">
  <div class="card"><div class="k">{{ qc.median_counts }}</div><div class="l">Median counts</div></div>
  <div class="card"><div class="k">{{ qc.median_genes }}</div><div class="l">Median genes</div></div>
  <div class="card"><div class="k">{{ "%.1f"|format(qc.median_pct_mito) }}%</div><div class="l">Median % mito</div></div>
  <div class="card"><div class="k">{{ qc.n_obs_before }} → {{ qc.n_obs_after }}</div><div class="l">Cells kept</div></div>
</div>
{% endif %}

<h2>Interactive spatial viewer</h2>
<noscript>
  <p style="color:#E45756">JavaScript is disabled — showing static plots.</p>
</noscript>
<div id="vitessce-container" class="vitessce-container">
  <div class="vitessce-loading">Loading Vitessce interactive viewer…</div>
</div>

<h2>Static spatial maps (SVG fallback)</h2>
<div class="plots">
  {% for plot in plots %}<div>{{ plot|safe }}</div>{% endfor %}
</div>

{% if annotation_counts %}
<h2>Annotation summary</h2>
<div class="overflow">
<table>
  <thead><tr><th>Label</th><th>Cells</th><th>Fraction</th></tr></thead>
  <tbody>
  {% for row in annotation_counts %}
    <tr><td>{{ row.label }}</td><td>{{ row.count }}</td><td>{{ "%.1f"|format(row.pct) }}%</td></tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% endif %}

{% if compiler %}
<h2>Compiler plan</h2>
<div class="card">
  <p><b>Question:</b> {{ compiler.question }}</p>
  <p><b>Rationale:</b> {{ compiler.rationale }}</p>
  {% if compiler.plan_id %}
  <p><b>Plan ID:</b> <code>{{ compiler.plan_id }}</code>
     &middot; <b>Schema:</b> <code>v{{ compiler.schema_version }}</code>
     &middot; <b>Attempts:</b> <code>{{ compiler.attempt_count }}</code></p>
  {% endif %}
  <p><b>Assay assumed:</b> <code>{{ compiler.assay_assumed }}</code>
     &middot; <b>Model:</b> <code>{{ compiler.model }}</code>
     &middot; <b>Executor:</b> <code>{{ compiler.executor }}</code></p>
  {% if compiler.gaps %}
  <p><b>Capability approximations:</b></p>
  <ul>
    {% for gap in compiler.gaps %}
    <li><code>{{ gap.concept }}</code>: {{ gap.reason }} &rarr; {{ gap.degraded_to }}</li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
{% endif %}

<h2>Pipeline &amp; provenance</h2>
<p>Every step below is recorded with its method version and parameters, so this run is
fully reproducible.</p>
<div class="overflow">
<table>
  <thead><tr><th>#</th><th>Step</th><th>Method</th><th>Version</th><th>Params</th><th>Obs after</th><th>Time (s)</th></tr></thead>
  <tbody>
  {% for step in steps %}
    <tr>
      <td>{{ loop.index }}</td>
      <td>{{ step.category }}</td>
      <td><code>{{ step.method }}</code></td>
      <td>{{ step.version }}</td>
      <td><code>{{ step.params }}</code></td>
      <td>{{ step.n_obs_after }}</td>
      <td>{{ step.seconds }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
</div>

<footer>
  Generated by HistoWeave — open-source spatial transcriptomics orchestration &amp;
  evaluation. Interactive exploration powered by
  <a href="https://vitessce.io" rel="noopener">Vitessce</a>.
</footer>

<!-- Inline Vitessce payload (config + inline CSV data files) -->
<script id="vitessce-payload" type="application/json">{{ vitessce_json|safe }}</script>

<!--
  Vitessce v3.5.7 is an ES module with react / react-dom peer dependencies.
  The official distribution is loaded from jsdelivr; inline CSV strings are
  rewritten to blob URLs before the React component is mounted.
-->
<script type="importmap">
{
  "imports": {
    "react": "https://esm.sh/react@18.3.1",
    "react-dom": "https://esm.sh/react-dom@18.3.1",
    "react-dom/client": "https://esm.sh/react-dom@18.3.1/client",
    "vitessce": "https://cdn.jsdelivr.net/npm/vitessce@3.5.7/dist/index.min.js"
  }
}
</script>
<script type="module">
  const container = document.getElementById('vitessce-container');
  const fail = (msg) => {
    container.innerHTML = '<div class="vitessce-error">' + msg +
      ' — see static plots below.</div>';
    container.style.minHeight = 'auto';
  };
  try {
    const payloadEl = document.getElementById('vitessce-payload');
    const raw = JSON.parse(payloadEl.textContent || '{}');
    if (!raw || !raw.config || !raw.config.datasets) {
      fail('No spatial data available for interactive viewer');
    } else {
      const [React, { createRoot }, vitessce] = await Promise.all([
        import('react'),
        import('react-dom/client'),
        import('vitessce'),
      ]);
      const Vitessce = vitessce.Vitessce;
      if (!Vitessce) throw new Error('Vitessce component not found in module');

      const dataFiles = raw.data || {};
      raw.config.datasets.forEach((dataset) => {
        (dataset.files || []).forEach((file) => {
          const ref = typeof file.url === 'string' && file.url.startsWith('inline:')
            ? file.url.slice('inline:'.length) : null;
          if (ref && dataFiles[ref] != null) {
            const blob = new Blob([dataFiles[ref]], { type: 'text/csv' });
            file.url = URL.createObjectURL(blob);
          }
        });
      });

      const loading = container.querySelector('.vitessce-loading');
      if (loading) loading.remove();

      // --- Bidirectional linking (task 3) ---------------------------------
      // Vitessce views already share coordination scopes (obsSetSelection,
      // obsHighlight, featureSelection), so brushing/linking between the
      // scatterplot, obsSets and heatmap is native. Here we add the extra
      // "select cluster -> show its top marker genes -> update the heatmap"
      // behaviour by watching obsSetSelection and rewriting featureSelection
      // to the selected cluster's markers from the embedded marker map.
      const markerMap = raw.cluster_top_markers || {};
      const primaryLabel = raw.primary_label;

      const flattenSelection = (sel) => {
        // obsSetSelection is a list of set paths like [["Domain","domain_2"], ...]
        if (!Array.isArray(sel)) return [];
        return sel
          .filter((p) => Array.isArray(p) && p.length >= 2)
          .map((p) => ({ hierarchy: String(p[0]), node: String(p[p.length - 1]) }));
      };

      const markersForSelection = (sel) => {
        const picks = flattenSelection(sel);
        const genes = [];
        for (const { hierarchy, node } of picks) {
          const byCluster = markerMap[hierarchy] || (primaryLabel ? markerMap[primaryLabel] : null);
          if (byCluster && byCluster[node]) {
            for (const g of byCluster[node]) if (!genes.includes(g)) genes.push(g);
          }
        }
        return genes;
      };

      // Controlled Vitessce: we own the config and update featureSelection when
      // the shared obsSetSelection scope changes.
      let currentConfig = raw.config;
      let lastSelectionKey = '';
      const App = () => {
        const [cfg, setCfg] = React.useState(currentConfig);
        const onConfigChange = (next) => {
          try {
            const cs = (next && next.coordinationSpace) || {};
            const sel = cs.obsSetSelection ? cs.obsSetSelection.A : null;
            const key = JSON.stringify(sel);
            if (key !== lastSelectionKey) {
              lastSelectionKey = key;
              const genes = markersForSelection(sel);
              if (genes.length && next.coordinationSpace.featureSelection) {
                next = JSON.parse(JSON.stringify(next));
                next.coordinationSpace.featureSelection.A = genes;
              }
            }
          } catch (_e) { /* keep viewer alive on any linking error */ }
          currentConfig = next;
          setCfg(next);
        };
        return React.createElement(Vitessce, {
          config: cfg,
          onConfigChange,
          theme: 'light',
          height: 520,
        });
      };
      createRoot(container).render(React.createElement(App));
      container.setAttribute('data-vitessce-ready', 'true');
      container.setAttribute('data-linking', 'enabled');
    }
  } catch (error) {
    fail('Vitessce initialisation error: ' +
      (error && error.message ? error.message : error));
  }
</script>
</body>
</html>
